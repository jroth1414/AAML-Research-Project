# .env.example — copy to .env and fill in; .env is gitignored, NEVER commit it.
#
# The AI4Mars dataset is openly downloadable (NASA), so NO credentials are required for the core
# pipeline. These are optional conveniences only.

# Optional experiment tracking (packages NOT in requirements.txt; leave blank to disable)
WANDB_API_KEY=
WANDB_MODE=offline

# Optional: a Hugging Face token (only if a gated SegFormer/DINOv2/SAM checkpoint needs auth)
HF_TOKEN=
