# .env.example — copy to .env and fill in; .env is gitignored, NEVER commit it.
#
# The AI4Mars dataset itself is openly downloadable (NASA/Zenodo) — no credentials needed for the
# core pipeline (H1–H4). The H5 foundation reference is the exception: the DINOv3 SAT-493M weights
# are GATED on Hugging Face and REQUIRE a token.

# REQUIRED for H5 (DINOv3): a Hugging Face READ token, after accepting the license at
# https://huggingface.co/facebook/dinov3-vitl16-pretrain-sat493m
# Absent/empty => the H5 DINOv3 arm skip-and-logs (status="skipped"); H1–H4 are unaffected.
HF_TOKEN=

# Optional experiment tracking (packages NOT in requirements.txt; leave blank to disable)
WANDB_API_KEY=
WANDB_MODE=offline
