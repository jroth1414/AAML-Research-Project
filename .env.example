# .env.example  — copy to .env and fill in; .env is gitignored, NEVER commit it.

# NASA Earthdata (Black Marble VNP46A3).
# Preferred: a bearer token from https://urs.earthdata.nasa.gov/ (profile -> Generate Token).
# Token is valid ~60 days; regenerate when downloads start returning 401/403.
EARTHDATA_TOKEN=
BLACKMARBLE_TOKEN=        # set equal to EARTHDATA_TOKEN; blackmarblepy reads this name
# Alternative to a token: username/password used to write ~/.netrc (or _netrc on Windows)
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# FRED (St. Louis Fed). Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional experiment tracking (leave blank to disable; packages are NOT in requirements.txt)
MLFLOW_TRACKING_URI=
WANDB_API_KEY=
WANDB_MODE=offline
